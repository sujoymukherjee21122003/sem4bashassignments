#Write a shell script to print the following pattern:
#   *   
#   *   *   
#   *   *   *   
#   *   *   *   
#   *   *
#   *

#!/usr/bin/bash
 
read -p "Enter the maximum number of stars :: " n

# Upper half
for ((i=1; i<=n; i++))
do
    for ((j=1; j<=i; j++))
    do
        echo -n "*   "
    done
    echo
done

# Lower half
for ((i=n-1; i>=1; i--))
do
    for ((j=1; j<=i; j++))
    do
        echo -n "*   "
    done
    echo
done
